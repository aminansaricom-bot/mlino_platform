DATABASE_URL="postgresql://mlino:mlino@localhost:5432/mlino?schema=public"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
PORT=4001

# Auth hardening (all optional — sensible defaults if unset)
# REFRESH_TOKEN_TTL_MS=2592000000   # default: 30 days
# RESET_TOKEN_TTL_MS=3600000        # default: 1 hour
# AUTH_THROTTLE_LIMIT=5             # default: 5 requests
# AUTH_THROTTLE_TTL_MS=60000        # default: per 60 seconds, on /auth/login and /auth/register

# LLM Gateway (MVP default: mock provider, no key needed)
LLM_PROVIDER="mock"          # mock | openai
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

NEXT_PUBLIC_API_URL="http://localhost:4001"
